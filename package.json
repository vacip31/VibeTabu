{
  "name": "vibeparty-portal",
  "version": "1.0.0",
  "description": "Tailwind CSS compilation scripts for VibeParty",
  "scripts": {
    "build:css:hub": "npx tailwindcss -i ./css/tailwind-input.css -o ./css/tailwind-hub.css -c ./tailwind.config.js --minify",
    "build:css:taboo": "npx tailwindcss -i ./css/tailwind-input.css -o ./css/tailwind-taboo.css -c ./tailwind.taboo.config.js --minify",
    "build:css:verses": "npx tailwindcss -i ./css/tailwind-input.css -o ./css/tailwind-verses.css -c ./tailwind.verses.config.js --minify",
    "build:css": "npm run build:css:hub && npm run build:css:taboo && npm run build:css:verses"
  },
  "devDependencies": {
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.9",
    "tailwindcss": "^3.4.17"
  }
}
